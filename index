<script>
/* ══════════════════════════════════════════════════
   TABS
══════════════════════════════════════════════════ */
function switchTab(idx) {
  document.querySelectorAll('.tab').forEach((t, i) => t.classList.toggle('active', i === idx));
  document.querySelectorAll('.panel').forEach((p, i) => p.classList.toggle('active', i === idx));
}

/* ══════════════════════════════════════════════════
   PANEL 01 — PASSWORD ANALYZER
══════════════════════════════════════════════════ */
function togglePwVis() {
  const inp = document.getElementById('pw-input');
  const btn = document.querySelector('.input-action');
  if (inp.type === 'password') {
    inp.type = 'text';
    btn.textContent = '[HIDE]';
  } else {
    inp.type = 'password';
    btn.textContent = '[SHOW]';
  }
}

const COMMON = ['password','passw0rd','qwerty','letmein','welcome','monkey','dragon','master','login','abc123','111111','123456','password1','iloveyou','admin','root','toor','test','guest'];
const LEET = {'@':'a','3':'e','1':'i','0':'o','5':'s','$':'s','7':'t'};
const KBD_WALKS = ['qwerty','asdfgh','zxcvbn','qweasd','123456','654321','!@#$%^'];

function analyzePw() {
  const pw = document.getElementById('pw-input').value;
  const len = pw.length;

  // Charset
  const hasUpper  = /[A-Z]/.test(pw);
  const hasLower  = /[a-z]/.test(pw);
  const hasDigit  = /[0-9]/.test(pw);
  const hasSymbol = /[^a-zA-Z0-9]/.test(pw);
  let charset = 0;
  if (hasLower)  charset += 26;
  if (hasUpper)  charset += 26;
  if (hasDigit)  charset += 10;
  if (hasSymbol) charset += 32;

  const entropy = len > 0 ? Math.round(len * Math.log2(Math.max(charset, 1))) : 0;
  const unique  = new Set(pw).size;

  // Patterns
  const normalized = pw.toLowerCase().replace(/@/g,'a').replace(/3/g,'e').replace(/1/g,'i').replace(/0/g,'o').replace(/5/g,'s').replace(/\$/g,'s').replace(/7/g,'t');
  const isLeet = normalized !== pw.toLowerCase() && COMMON.some(w => normalized.includes(w));
  const hasSeq  = /(?:abc|bcd|cde|def|efg|fgh|ghi|hij|ijk|jkl|klm|lmn|mno|nop|opq|pqr|qrs|rst|stu|tuv|uvw|vwx|wxy|xyz|012|123|234|345|456|567|678|789)/i.test(pw);
  const hasRep  = /(.)\1{2,}/.test(pw);
  const hasKbd  = KBD_WALKS.some(w => pw.toLowerCase().includes(w));
  const hasCommon = COMMON.some(w => pw.toLowerCase().includes(w));
  const hasDate = /\b(19|20)\d{2}\b/.test(pw) || /\b\d{1,2}[\/\-\.]\d{1,2}[\/\-\.]\d{2,4}\b/.test(pw);

  // Checks
  setCheck('chk-len',    len >= 12);
  setCheck('chk-upper',  hasUpper);
  setCheck('chk-lower',  hasLower);
  setCheck('chk-digit',  hasDigit);
  setCheck('chk-symbol', hasSymbol);
  setCheck('chk-20',     len >= 20);

  // Warnings (warn = bad = show in red/orange)
  setWarn('warn-seq',    hasSeq);
  setWarn('warn-rep',    hasRep);
  setWarn('warn-kbd',    hasKbd);
  setWarn('warn-common', hasCommon);
  setWarn('warn-leet',   isLeet);
  setWarn('warn-date',   hasDate);

  // Score 0–100
  let score = 0;
  if (len > 0)   score += Math.min(30, len * 2.5);
  if (hasUpper)  score += 10;
  if (hasLower)  score += 10;
  if (hasDigit)  score += 10;
  if (hasSymbol) score += 20;
  if (len >= 20) score += 10;
  if (hasSeq || hasRep || hasKbd) score -= 15;
  if (hasCommon) score -= 25;
  if (isLeet)    score -= 10;
  if (hasDate)   score -= 10;
  score = Math.max(0, Math.min(100, score));

  // Crack time
  const combinations = charset > 0 ? Math.pow(charset, len) : 0;
  const guessesPerSec = 1e12;
  const seconds = combinations / guessesPerSec;
  let crackStr = '—';
  if (len === 0) crackStr = '—';
  else if (seconds < 1)       crackStr = 'Instant';
  else if (seconds < 60)      crackStr = '<1 min';
  else if (seconds < 3600)    crackStr = Math.round(seconds/60)+'m';
  else if (seconds < 86400)   crackStr = Math.round(seconds/3600)+'h';
  else if (seconds < 2592000) crackStr = Math.round(seconds/86400)+'d';
  else if (seconds < 31536000)crackStr = Math.round(seconds/2592000)+'mo';
  else if (seconds < 3153600000) crackStr = Math.round(seconds/31536000)+'yr';
  else crackStr = '>1000yr';

  // Bar
  const bar = document.getElementById('strength-bar');
  let color, label;
  if (len === 0)     { color = 'var(--muted)'; label = 'AWAITING INPUT'; score = 0; }
  else if (score < 25)  { color = 'var(--red)';    label = 'CRITICAL: VERY WEAK'; }
  else if (score < 45)  { color = 'var(--orange)'; label = 'WARN: WEAK'; }
  else if (score < 65)  { color = 'var(--yellow)'; label = 'FAIR'; }
  else if (score < 80)  { color = 'var(--text)';   label = 'STRONG'; }
  else                   { color = 'var(--text)';  label = 'VERY STRONG'; }

  bar.style.width = score + '%';
  bar.style.background = color;
  document.getElementById('strength-label').textContent = label;
  document.getElementById('strength-label').style.color = color;
  document.getElementById('entropy-val').textContent = len > 0 ? entropy : '—';
  document.getElementById('pw-len').textContent     = len;
  document.getElementById('pw-charset').textContent  = charset || '—';
  document.getElementById('pw-unique').textContent   = len > 0 ? unique : '—';
  document.getElementById('pw-crack').textContent    = crackStr;

  // Recommendations
  const recs = [];
  if (!len)         recs.push('> Start typing a password to begin analysis...');
  else {
    if (len < 12)   recs.push('[!] Increase length to at least 12 characters.');
    if (!hasUpper)  recs.push('[!] Add uppercase letters.');
    if (!hasLower)  recs.push('[!] Add lowercase letters.');
    if (!hasDigit)  recs.push('[!] Include numbers.');
    if (!hasSymbol) recs.push('[!] Include symbols like !@#$%^&*.');
    if (hasCommon)  recs.push('[WARN] Avoid common dictionary words.');
    if (hasSeq)     recs.push('[WARN] Remove sequential character patterns.');
    if (hasRep)     recs.push('[WARN] Avoid repeated characters (e.g. "aaa").');
    if (hasKbd)     recs.push('[WARN] Avoid keyboard walks (e.g. "qwerty").');
    if (isLeet)     recs.push('[WARN] Leet-speak substitutions do not improve security.');
    if (len >= 20 && score >= 80) recs.push('[OK] Excellent. Consider storing in a password manager.');
    else if (score >= 65) recs.push('[OK] Good password. Passphrases are even stronger.');
  }
  document.getElementById('pw-recommendations').innerHTML = recs.map(r => `<div>${r}</div>`).join('');
}

function setCheck(id, pass) {
  const el = document.getElementById(id);
  el.className = 'check-item' + (pass ? ' pass' : '');
}

function setWarn(id, bad) {
  const el = document.getElementById(id);
  el.className = 'check-item' + (bad ? ' warn' : ' pass');
}

/* ══════════════════════════════════════════════════
   PANEL 02 — HASH GENERATOR
══════════════════════════════════════════════════ */
let currentAlgo = 'MD5';

function setAlgo(algo, el) {
  currentAlgo = algo;
  document.querySelectorAll('.algo-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('algo-label').textContent = algo.replace('SHA256','SHA-256').replace('SHA512','SHA-512').replace('SHA1','SHA-1').replace('SHA3','SHA-3');
}

function generateHash() {
  const input = document.getElementById('hash-input').value;
  if (!input.trim()) { showHashOut('ERR: NO_INPUT_DETECTED', true); return; }
  computeHash(input);
}

function computeHash(input) {
  let hash;
  try {
    switch(currentAlgo) {
      case 'MD5':      hash = CryptoJS.MD5(input).toString(); break;
      case 'SHA1':     hash = CryptoJS.SHA1(input).toString(); break;
      case 'SHA256':   hash = CryptoJS.SHA256(input).toString(); break;
      case 'SHA512':   hash = CryptoJS.SHA512(input).toString(); break;
      case 'SHA3':     hash = CryptoJS.SHA3(input).toString(); break;
      case 'RIPEMD160':hash = CryptoJS.RIPEMD160(input).toString(); break;
      default:         hash = CryptoJS.SHA256(input).toString();
    }
    showHashOut(hash, false);
  } catch(e) { showHashOut('ERR: ' + e.message, true); }
}

function hashFile() {
  const file = document.getElementById('hash-file').files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    const wordArray = CryptoJS.lib.WordArray.create(e.target.result);
    let hash;
    switch(currentAlgo) {
      case 'MD5':      hash = CryptoJS.MD5(wordArray).toString(); break;
      case 'SHA1':     hash = CryptoJS.SHA1(wordArray).toString(); break;
      case 'SHA256':   hash = CryptoJS.SHA256(wordArray).toString(); break;
      case 'SHA512':   hash = CryptoJS.SHA512(wordArray).toString(); break;
      case 'SHA3':     hash = CryptoJS.SHA3(wordArray).toString(); break;
      case 'RIPEMD160':hash = CryptoJS.RIPEMD160(wordArray).toString(); break;
      default:         hash = CryptoJS.SHA256(wordArray).toString();
    }
    document.getElementById('hash-input').value = `[FILE_LOADED: ${file.name} — ${(file.size/1024).toFixed(1)} KB]`;
    showHashOut(hash, false);
  };
  reader.readAsArrayBuffer(file);
}

function showHashOut(text, empty) {
  const el = document.getElementById('hash-output');
  el.className = 'output-field' + (empty ? ' empty' : '');
  el.innerHTML = text + '<button class="copy-btn" onclick="copyHash()">[COPY]</button>';
}

function copyHash() {
  const text = document.getElementById('hash-output').textContent.replace('[COPY]','').trim();
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('#hash-output .copy-btn');
    if(btn) { btn.textContent = '[COPIED]'; setTimeout(()=>btn.textContent='[COPY]', 1500); }
  });
}

function verifyHash() {
  const expected = document.getElementById('verify-input').value.trim().toLowerCase();
  const generated = document.getElementById('hash-output').textContent.replace('[COPY]','').trim().toLowerCase();
  const res = document.getElementById('verify-result');
  res.className = '';
  if (!expected || !generated || generated === '—') {
    res.className = 'verify-result no-match';
    res.innerHTML = '[!] Awaiting hash generation and expected input...';
    return;
  }
  if (expected === generated) {
    res.className = 'verify-result match';
    res.innerHTML = '[OK] MATCH — Integrity verified.';
  } else {
    res.className = 'verify-result no-match';
    res.innerHTML = '[FAIL] NO MATCH — Potential tampering detected.';
  }
}

/* ══════════════════════════════════════════════════
   PANEL 03 — CVE LOOKUP
══════════════════════════════════════════════════ */
function quickCve(id) {
  document.getElementById('cve-input').value = id;
  lookupCve();
}

async function lookupCve() {
  const query = document.getElementById('cve-input').value.trim();
  if (!query) return;

  const loading = document.getElementById('cve-loading');
  const errEl   = document.getElementById('cve-error');
  const results = document.getElementById('cve-results');

  loading.classList.remove('hidden');
  errEl.className = 'hidden';
  results.innerHTML = '';

  const isCveId = /^CVE-\d{4}-\d+$/i.test(query);
  const url = isCveId
    ? `https://services.nvd.nist.gov/rest/json/cves/2.0?cveId=${encodeURIComponent(query.toUpperCase())}`
    : `https://services.nvd.nist.gov/rest/json/cves/2.0?keywordSearch=${encodeURIComponent(query)}&resultsPerPage=8`;

  try {
    const res  = await fetch(url);
    const data = await res.json();
    loading.classList.add('hidden');

    const vulns = data.vulnerabilities || [];
    if (!vulns.length) {
      results.innerHTML = `<div class="empty-state"><div class="empty-icon">/0/</div>NO_RECORDS_FOUND<br>Query: "${query}"</div>`;
      return;
    }

    results.innerHTML = `<div style="font-size:0.72rem;color:var(--muted);margin-bottom:14px;">[+] Query matched ${data.totalResults} record(s) — displaying ${vulns.length}</div>`;

    vulns.forEach(v => {
      const cve   = v.cve;
      const id    = cve.id;
      const descs = cve.descriptions || [];
      const desc  = (descs.find(d => d.lang === 'en') || descs[0] || {}).value || 'No description available.';
      const metrics = cve.metrics || {};
      let score = null, severity = null;

      // Try CVSS v3.1 first, then v3.0, then v2
      const m31 = metrics.cvssMetricV31?.[0]?.cvssData;
      const m30 = metrics.cvssMetricV30?.[0]?.cvssData;
      const m2  = metrics.cvssMetricV2?.[0]?.cvssData;
      if (m31)       { score = m31.baseScore; severity = m31.baseSeverity; }
      else if (m30)  { score = m30.baseScore; severity = m30.baseSeverity; }
      else if (m2)   { score = m2.baseScore;  severity = m2.baseSeverity; }

      const published = cve.published ? new Date(cve.published).toLocaleDateString('en-GB', {year:'numeric',month:'short',day:'numeric'}) : '—';
      const modified  = cve.lastModified ? new Date(cve.lastModified).toLocaleDateString('en-GB', {year:'numeric',month:'short',day:'numeric'}) : '—';
      const refs      = (cve.references || []).slice(0, 3);

      let badgeClass = 'cvss-none';
      let badgeText  = 'N/A';
      if (severity) {
        const s = severity.toLowerCase();
        badgeText = severity + (score ? ' ' + score : '');
        if (s === 'critical') badgeClass = 'cvss-critical';
        else if (s === 'high') badgeClass = 'cvss-high';
        else if (s === 'medium') badgeClass = 'cvss-medium';
        else if (s === 'low') badgeClass = 'cvss-low';
      }

      results.innerHTML += `
        <div class="cve-card">
          <div class="cve-header">
            <span class="cve-id">${id}</span>
            <span class="cvss-badge ${badgeClass}">${badgeText}</span>
          </div>
          <div class="cve-desc">${desc.length > 400 ? desc.slice(0, 400) + '…' : desc}</div>
          <div class="cve-meta">
            <div class="cve-meta-item">PUB: <span>${published}</span></div>
            <div class="cve-meta-item">MOD: <span>${modified}</span></div>
            ${refs.length ? `<div class="cve-meta-item" style="margin-left:auto;">${refs.map(r=>`<a class="cve-link" href="${r.url}" target="_blank" rel="noopener">[EXT_LINK]</a>`).join(' &nbsp; ')}</div>` : ''}
          </div>
        </div>`;
    });

  } catch(err) {
    loading.classList.add('hidden');
    errEl.className = 'msg msg-error';
    errEl.innerHTML = `[ERR] NVD_API_UNREACHABLE<br><small style="opacity:0.6">${err.message}</small>`;
  }
}

/* ══════════════════════════════════════════════════
   PANEL 04 — SSL DECODER
══════════════════════════════════════════════════ */
function decodeSsl() {
  const pem  = document.getElementById('ssl-input').value.trim();
  const err  = document.getElementById('ssl-error');
  const res  = document.getElementById('ssl-result');

  err.className = 'hidden';
  res.innerHTML = '';

  if (!pem) { err.className='msg msg-error'; err.textContent='[ERR] PEM_DATA_REQUIRED'; return; }

  try {
    const cert = forge.pki.certificateFromPem(pem);

    const getField = (obj, key) => {
      const attr = obj.attributes.find(a => a.name === key || a.shortName === key);
      return attr ? attr.value : '—';
    };

    // Subject
    const subjectCN = getField(cert.subject, 'commonName');
    const subjectO  = getField(cert.subject, 'organizationName');
    const subjectOU = getField(cert.subject, 'organizationalUnitName');
    const subjectC  = getField(cert.subject, 'countryName');
    const subjectST = getField(cert.subject, 'stateOrProvinceName');

    // Issuer
    const issuerCN = getField(cert.issuer, 'commonName');
    const issuerO  = getField(cert.issuer, 'organizationName');

    // Validity
    const notBefore = cert.validity.notBefore;
    const notAfter  = cert.validity.notAfter;
    const now       = new Date();
    const isExpired = now > notAfter;
    const isNotYet  = now < notBefore;
    const daysLeft  = Math.round((notAfter - now) / 86400000);

    // SANs
    const sanExt = cert.extensions.find(e => e.name === 'subjectAltName');
    const sans   = sanExt ? (sanExt.altNames || []).map(a => a.value) : [];

    // Key info
    const pk   = cert.publicKey;
    let keyInfo = '—';
    try {
      if (pk.n) keyInfo = `RSA ${pk.n.bitLength()} bit`;
      else if (pk.curve) keyInfo = `EC ${pk.curve}`;
      else keyInfo = 'Unknown';
    } catch(e) {}

    // Serial
    const serial = cert.serialNumber;

    // Signature algo
    const sigAlgo = cert.signatureOid;
    const sigNames = {
      '1.2.840.113549.1.1.11': 'SHA256withRSA',
      '1.2.840.113549.1.1.12': 'SHA384withRSA',
      '1.2.840.113549.1.1.13': 'SHA512withRSA',
      '1.2.840.10045.4.3.2':   'SHA256withECDSA',
      '1.2.840.10045.4.3.3':   'SHA384withECDSA',
      '1.2.840.10045.4.3.4':   'SHA512withECDSA',
    };

    // Fingerprint (SHA-256)
    const md = forge.md.sha256.create();
    md.update(forge.asn1.toDer(forge.pki.certificateToAsn1(cert)).getBytes());
    const fp = md.digest().toHex().match(/.{2}/g).join(':').toUpperCase();

    const validityClass = isExpired ? 'expired' : (isNotYet ? 'warn' : 'valid');
    const validityStatus = isExpired ? '[FAIL] EXPIRED' : (isNotYet ? '[WARN] NOT YET VALID' : `[OK] VALID (T-${daysLeft} DAYS)`);

    res.innerHTML = `
      <div class="msg msg-${isExpired ? 'error' : (isNotYet ? 'error' : 'ok')}" style="margin-bottom:18px">
        ${isExpired ? '[!] CERTIFICATE HAS EXPIRED.' : (isNotYet ? '[!] CERTIFICATE NOT YET ACTIVE.' : `[+] CERTIFICATE VALID. EXP: ${daysLeft} DAYS.`)}
      </div>

      <div class="card" style="margin-bottom:16px">
        <div class="card-title">Subject Data</div>
        <div class="ssl-grid">
          <div class="ssl-field"><div class="ssl-field-label">Common Name (CN)</div><div class="ssl-field-value">${subjectCN}</div></div>
          <div class="ssl-field"><div class="ssl-field-label">Organization (O)</div><div class="ssl-field-value">${subjectO}</div></div>
          <div class="ssl-field"><div class="ssl-field-label">Org. Unit (OU)</div><div class="ssl-field-value">${subjectOU}</div></div>
          <div class="ssl-field"><div class="ssl-field-label">Country</div><div class="ssl-field-value">${subjectC} ${subjectST !== '—' ? '/ '+subjectST : ''}</div></div>
        </div>
      </div>

      <div class="card" style="margin-bottom:16px">
        <div class="card-title">Issuer Data</div>
        <div class="ssl-grid">
          <div class="ssl-field"><div class="ssl-field-label">Common Name (CN)</div><div class="ssl-field-value">${issuerCN}</div></div>
          <div class="ssl-field"><div class="ssl-field-label">Organization (O)</div><div class="ssl-field-value">${issuerO}</div></div>
        </div>
      </div>

      <div class="card" style="margin-bottom:16px">
        <div class="card-title">Validity & Cryptography</div>
        <div class="ssl-grid">
          <div class="ssl-field"><div class="ssl-field-label">Not Before</div><div class="ssl-field-value">${notBefore.toUTCString()}</div></div>
          <div class="ssl-field ${validityClass}"><div class="ssl-field-label">Not After</div><div class="ssl-field-value">${notAfter.toUTCString()}</div></div>
          <div class="ssl-field"><div class="ssl-field-label">Status</div><div class="ssl-field-value ${isExpired?'ssl-field expired':(!isNotYet?'ssl-field valid':'')}">${validityStatus}</div></div>
          <div class="ssl-field"><div class="ssl-field-label">Public Key</div><div class="ssl-field-value">${keyInfo}</div></div>
          <div class="ssl-field"><div class="ssl-field-label">Signature Algorithm</div><div class="ssl-field-value">${sigNames[sigAlgo] || sigAlgo}</div></div>
          <div class="ssl-field"><div class="ssl-field-label">Serial Number</div><div class="ssl-field-value">${serial}</div></div>
        </div>
      </div>

      ${sans.length ? `
      <div class="card" style="margin-bottom:16px">
        <div class="card-title">Subject Alternative Names (SANs: ${sans.length})</div>
        <div>${sans.map(s=>`<span class="san-tag">${s}</span>`).join('')}</div>
      </div>` : ''}

      <div class="card">
        <div class="card-title">SHA-256 Fingerprint</div>
        <div style="font-size:0.72rem; word-break:break-all; color:var(--text); font-family:var(--mono)">${fp}</div>
      </div>`;

  } catch(e) {
    err.className = 'msg msg-error';
    err.innerHTML = `[ERR] PARSE_FAILED<br><small style="opacity:0.6">${e.message}</small>`;
  }
}

