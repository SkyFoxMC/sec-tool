<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SEC/TOOLS — IT Security Toolkit</title>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/forge/1.3.1/forge.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* Classic Terminal Palette */
      --bg:       #020202;
      --s1:       #080a08;
      --s2:       #0b100b;
      --s3:       #101810;
      --border:   #003300;
      --border2:  #005500;
      --text:     #33ff33; /* Phosphor Green */
      --muted:    #00aa00; /* Dimmer Green */
      
      /* Accent colors scaled for the dark theme */
      --cyan:     #33ff33; /* Mapped to green to maintain the monochrome feel */
      --green:    #33ff33;
      --red:      #ff3333;
      --orange:   #ffaa00;
      --yellow:   #ffff33;
      
      --mono:     'IBM Plex Mono', monospace;
      --display:  'IBM Plex Mono', monospace; /* Forced monospace for headers too */
    }

    html { font-size: 14px; scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      min-height: 100vh;
      line-height: 1.6;
      overflow-x: hidden;
      /* Subtle CRT phosphor glow */
      text-shadow: 0 0 3px rgba(51, 255, 51, 0.4);
    }

    /* Dot grid background - updated to green */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      background-image: radial-gradient(circle, #002200 1px, transparent 1px);
      background-size: 28px 28px;
      opacity: 0.8;
      pointer-events: none;
    }

    /* Scanline overlay - slightly harsher for terminal feel */
    body::after {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.15) 2px,
        rgba(0, 0, 0, 0.15) 4px
      );
      pointer-events: none;
    }

    /* ── HEADER ───────────────────────────────────── */
    header {
      position: relative; z-index: 10;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(51,255,51,0.05) 0%, transparent 100%);
      padding: 28px 40px 24px;
      display: flex;
      align-items: flex-end;
      gap: 32px;
    }

    .logo {
      font-family: var(--display);
      font-weight: 600;
      font-size: 2.6rem;
      letter-spacing: -0.02em;
      color: var(--text);
      line-height: 1;
    }

    .logo span {
      color: var(--muted);
    }

    .header-meta {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding-bottom: 3px;
    }

    .tagline {
      font-size: 0.75rem;
      color: var(--muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .status-bar {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 0.7rem;
      color: var(--muted);
    }

    .status-dot {
      width: 6px; height: 6px;
      background: var(--text);
      box-shadow: 0 0 8px var(--text);
      animation: blink 1s step-end infinite;
    }

    .cursor {
      display: inline-block;
      width: 12px; height: 1.1em;
      background: var(--text);
      vertical-align: text-bottom;
      margin-left: 8px;
      animation: blink 1s step-end infinite;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    /* ── TABS ─────────────────────────────────────── */
    .tabs-wrapper {
      position: relative; z-index: 10;
      border-bottom: 1px solid var(--border);
      background: var(--bg);
      padding: 0 40px;
      display: flex;
      gap: 4px;
      overflow-x: auto;
      padding-top: 10px;
    }

    .tab {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      font-family: var(--mono);
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      color: var(--muted);
      border: 1px solid transparent;
      border-bottom: none;
      background: transparent;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
      text-transform: uppercase;
    }

    .tab:hover { 
      color: var(--text); 
      border-color: var(--border);
      background: var(--s1);
    }

    .tab.active {
      color: var(--bg);
      background: var(--text);
      border-color: var(--text);
      text-shadow: none; /* Remove glow for inverted text */
    }

    .tab-icon {
      font-size: 1rem;
    }

    .tab-num {
      font-size: 0.6rem;
      letter-spacing: 0;
    }

    /* ── PANELS ───────────────────────────────────── */
    main { position: relative; z-index: 10; padding: 36px 40px; max-width: 1000px; }

    .panel { display: none; }
    .panel.active { display: block; animation: scanReveal 0.3s ease-out; }

    @keyframes scanReveal {
      from { opacity: 0; clip-path: inset(0 100% 0 0); }
      to   { opacity: 1; clip-path: inset(0 0 0 0); }
    }

    /* ── SECTION TITLE ────────────────────────────── */
    .section-title {
      font-family: var(--display);
      font-weight: 600;
      font-size: 1.6rem;
      color: var(--text);
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .section-title .accent { color: var(--muted); }

    .section-desc {
      font-size: 0.75rem;
      color: var(--muted);
      margin-bottom: 28px;
      letter-spacing: 0.03em;
    }

    /* ── FORM ELEMENTS ────────────────────────────── */
    label {
      display: block;
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      margin-bottom: 6px;
    }

    input[type="text"],
    input[type="password"],
    textarea,
    select {
      width: 100%;
      background: var(--bg);
      border: 1px solid var(--border2);
      color: var(--text);
      font-family: var(--mono);
      font-size: 0.85rem;
      padding: 10px 14px;
      outline: none;
      transition: border-color 0.2s;
      resize: vertical;
    }

    input[type="text"]:focus,
    input[type="password"]:focus,
    textarea:focus,
    select:focus {
      border-color: var(--text);
      background: var(--s1);
      box-shadow: inset 0 0 8px rgba(51, 255, 51, 0.1);
    }

    textarea { min-height: 120px; }

    .input-wrap { position: relative; }

    .input-action {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 0.85rem;
      padding: 4px;
    }

    .input-action:hover { color: var(--text); }

    .field { margin-bottom: 18px; }

    /* ── BUTTONS ──────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 20px;
      border: 1px solid var(--text);
      background: transparent;
      color: var(--text);
      font-family: var(--mono);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.1s;
    }

    .btn:hover {
      background: var(--text);
      color: var(--bg);
      text-shadow: none;
    }

    .btn-ghost {
      border-color: var(--border2);
      color: var(--muted);
    }

    .btn-ghost:hover {
      border-color: var(--text);
      color: var(--bg);
      background: var(--text);
    }

    .btn-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 6px; }

    /* ── CARD ─────────────────────────────────────── */
    .card {
      background: var(--s1);
      border: 1px solid var(--border);
      padding: 20px 24px;
      margin-bottom: 16px;
    }

    .card-title {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      margin-bottom: 14px;
      border-bottom: 1px dashed var(--border2);
      padding-bottom: 6px;
    }

    /* ── OUTPUT FIELD ─────────────────────────────── */
    .output-field {
      background: var(--s1);
      border: 1px solid var(--border);
      border-left: 4px solid var(--text);
      padding: 12px 16px;
      font-size: 0.8rem;
      word-break: break-all;
      color: var(--text);
      position: relative;
      min-height: 44px;
    }

    .output-field.empty { color: var(--muted); border-left-color: var(--border2); }

    .copy-btn {
      position: absolute;
      top: 8px; right: 8px;
      background: var(--bg);
      border: 1px solid var(--border2);
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.65rem;
      padding: 3px 8px;
      cursor: pointer;
      letter-spacing: 0.06em;
    }

    .copy-btn:hover { color: var(--bg); background: var(--text); border-color: var(--text); text-shadow: none; }

    /* ── DIVIDER ──────────────────────────────────── */
    .divider {
      border: none;
      border-top: 1px dashed var(--border2);
      margin: 24px 0;
    }

    /* ── GRID ─────────────────────────────────────── */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

    /* ── STAT PILL ────────────────────────────────── */
    .stat {
      background: var(--s1);
      border: 1px solid var(--border);
      padding: 12px 14px;
      text-align: center;
    }

    .stat-val {
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--text);
      line-height: 1;
      margin-bottom: 4px;
    }

    .stat-lbl {
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
    }

    /* ── STRENGTH METER ───────────────────────────── */
    .strength-bar-wrap {
      height: 8px;
      background: var(--s3);
      border: 1px solid var(--border);
      overflow: hidden;
      margin: 14px 0 8px;
    }

    .strength-bar {
      height: 100%;
      width: 0%;
      background: var(--text);
      transition: width 0.4s ease;
    }

    .strength-label {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 600;
    }

    /* ── CHECK ITEMS ──────────────────────────────── */
    .checks { display: flex; flex-direction: column; gap: 6px; margin-top: 14px; }

    .check-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.78rem;
      color: var(--muted);
    }

    .check-item.pass { color: var(--text); }

    .check-dot {
      width: 10px; height: 10px;
      border: 1px solid var(--border2);
      flex-shrink: 0;
    }

    .check-item.pass .check-dot {
      background: var(--text);
      border-color: var(--text);
      box-shadow: 0 0 4px var(--text);
    }

    .check-item.warn .check-dot {
      background: var(--orange);
      border-color: var(--orange);
    }

    /* ── ALGO SELECTOR ────────────────────────────── */
    .algo-chips {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    .algo-chip {
      padding: 6px 16px;
      border: 1px solid var(--border2);
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.06em;
      color: var(--muted);
      background: var(--bg);
      cursor: pointer;
    }

    .algo-chip:hover { color: var(--text); border-color: var(--text); }
    .algo-chip.active { color: var(--bg); border-color: var(--text); background: var(--text); text-shadow: none; }

    /* ── CVE RESULT CARDS ─────────────────────────── */
    .cve-card {
      background: var(--s1);
      border: 1px solid var(--border);
      padding: 18px 20px;
      margin-bottom: 12px;
    }

    .cve-card:hover { border-color: var(--text); }

    .cve-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }

    .cve-id {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      letter-spacing: 0.04em;
    }

    .cvss-badge {
      flex-shrink: 0;
      padding: 3px 10px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      border: 1px solid currentColor;
    }

    .cvss-critical { color: var(--red); background: rgba(255,51,51,0.1); }
    .cvss-high     { color: var(--orange); background: rgba(255,170,0,0.1); }
    .cvss-medium   { color: var(--yellow); background: rgba(255,255,51,0.1); }
    .cvss-low      { color: var(--text); background: rgba(51,255,51,0.1); }
    .cvss-none     { color: var(--muted); }

    .cve-desc {
      font-size: 0.8rem;
      color: var(--text);
      line-height: 1.7;
      margin-bottom: 12px;
      opacity: 0.85;
    }

    .cve-meta {
      display: flex;
      gap: 20px;
      font-size: 0.68rem;
      color: var(--muted);
      flex-wrap: wrap;
    }

    .cve-meta-item span { color: var(--text); }

    .cve-link {
      font-size: 0.68rem;
      color: var(--text);
      text-decoration: none;
      border-bottom: 1px solid var(--muted);
    }

    .cve-link:hover { border-bottom-color: var(--text); }

    /* ── SSL FIELDS ───────────────────────────────── */
    .ssl-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .ssl-field {
      background: var(--bg);
      border: 1px solid var(--border2);
      padding: 12px 16px;
    }

    .ssl-field-label {
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      margin-bottom: 5px;
    }

    .ssl-field-value {
      font-size: 0.8rem;
      color: var(--text);
      word-break: break-all;
    }

    .ssl-field.full { grid-column: 1 / -1; }

    .ssl-field.expired .ssl-field-value { color: var(--red); }
    .ssl-field.valid .ssl-field-value { color: var(--text); }

    .san-tag {
      display: inline-block;
      background: var(--bg);
      border: 1px solid var(--border2);
      padding: 2px 8px;
      font-size: 0.72rem;
      color: var(--muted);
      margin: 2px;
    }

    /* ── LOADING / STATUS ─────────────────────────── */
    .loading {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.78rem;
      color: var(--text);
      padding: 20px 0;
    }

    .spinner {
      width: 16px; height: 16px;
      border: 2px solid var(--border2);
      border-top-color: var(--text);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .msg {
      padding: 12px 16px;
      font-size: 0.78rem;
      margin-bottom: 14px;
      border: 1px solid;
    }

    .msg-error { border-color: var(--red); color: var(--red); background: rgba(255,51,51,0.05); }
    .msg-info  { border-color: var(--text); color: var(--text); background: rgba(51,255,51,0.05); }
    .msg-ok    { border-color: var(--text); color: var(--text); background: rgba(51,255,51,0.1); }

    .hidden { display: none !important; }

    /* ── VERIFY ───────────────────────────────────── */
    .verify-result {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      font-size: 0.82rem;
      border: 1px solid;
    }

    .verify-result.match    { border-color: var(--text); color: var(--bg); background: var(--text); text-shadow:none; }
    .verify-result.no-match { border-color: var(--red); color: var(--red); background: rgba(255,51,51,0.1); }

    /* ── INPUT GROUP ──────────────────────────────── */
    .input-group {
      display: flex;
      gap: 0;
    }

    .input-group input {
      border-right: none;
    }

    .input-group .btn {
      white-space: nowrap;
    }

    /* ── RESPONSIVE ───────────────────────────────── */
    @media (max-width: 700px) {
      header { padding: 20px; flex-direction: column; align-items: flex-start; gap: 8px; }
      .tabs-wrapper { padding: 0 16px; }
      main { padding: 24px 20px; }
      .grid-2, .grid-3, .grid-4, .ssl-grid { grid-template-columns: 1fr; }
      .ssl-field.full { grid-column: 1; }
    }

    /* ── EMPTY STATE ──────────────────────────────── */
    .empty-state {
      text-align: center;
      padding: 48px 24px;
      color: var(--muted);
      font-size: 0.8rem;
      border: 1px dashed var(--border2);
    }

    .empty-icon { font-size: 2.5rem; margin-bottom: 12px; opacity: 0.5; }

  </style>
</head>
<body>

<header>
  <div class="logo">SEC<span>/</span>TOOLS<span class="cursor"></span></div>
  <div class="header-meta">
    <div class="tagline">IT Security Toolkit — Client-Side Only</div>
    <div class="status-bar">
      <div class="status-dot"></div>
      <span>No data transmitted externally &nbsp;·&nbsp; LOCALHOST READY</span>
    </div>
  </div>
</header>

<div class="tabs-wrapper">
  <button class="tab active" onclick="switchTab(0)">
    <span class="tab-icon">#</span> Password Analyzer
    <span class="tab-num">[01]</span>
  </button>
  <button class="tab" onclick="switchTab(1)">
    <span class="tab-icon">#</span> Hash Generator
    <span class="tab-num">[02]</span>
  </button>
  <button class="tab" onclick="switchTab(2)">
    <span class="tab-icon">#</span> CVE Lookup
    <span class="tab-num">[03]</span>
  </button>
  <button class="tab" onclick="switchTab(3)">
    <span class="tab-icon">#</span> SSL Decoder
    <span class="tab-num">[04]</span>
  </button>
</div>

<main>

  <div class="panel active" id="panel-0">
    <div class="section-title"><span class="accent">>_</span> Password Strength Analyzer</div>
    <div class="section-desc">Entirely client-side. Your password never leaves this terminal.</div>

    <div class="field">
      <label>Enter Password</label>
      <div class="input-wrap">
        <input type="password" id="pw-input" placeholder="Type your password..." oninput="analyzePw()" autocomplete="off" spellcheck="false">
        <button class="input-action" onclick="togglePwVis()" title="Toggle visibility">[SHOW]</button>
      </div>
    </div>

    <div class="strength-bar-wrap">
      <div class="strength-bar" id="strength-bar"></div>
    </div>
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:18px;">
      <span class="strength-label" id="strength-label" style="color: var(--muted)">AWAITING INPUT</span>
      <span style="font-size:0.72rem; color:var(--muted)">Entropy: <span id="entropy-val" style="color:var(--text)">—</span> bits</span>
    </div>

    <div class="grid-4" style="margin-bottom:18px;">
      <div class="stat"><div class="stat-val" id="pw-len">0</div><div class="stat-lbl">Length</div></div>
      <div class="stat"><div class="stat-val" id="pw-charset">0</div><div class="stat-lbl">Charset</div></div>
      <div class="stat"><div class="stat-val" id="pw-unique">0</div><div class="stat-lbl">Unique</div></div>
      <div class="stat"><div class="stat-val" id="pw-crack">—</div><div class="stat-lbl">Crack Time</div></div>
    </div>

    <div class="grid-2">
      <div class="card">
        <div class="card-title">Character Composition</div>
        <div class="checks" id="pw-checks">
          <div class="check-item" id="chk-len">    <div class="check-dot"></div> Min. 12 characters</div>
          <div class="check-item" id="chk-upper">  <div class="check-dot"></div> Uppercase letters (A–Z)</div>
          <div class="check-item" id="chk-lower">  <div class="check-dot"></div> Lowercase letters (a–z)</div>
          <div class="check-item" id="chk-digit">  <div class="check-dot"></div> Numbers (0–9)</div>
          <div class="check-item" id="chk-symbol"> <div class="check-dot"></div> Symbols (!@#$…)</div>
          <div class="check-item" id="chk-20">     <div class="check-dot"></div> 20+ characters</div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Pattern Warnings</div>
        <div class="checks" id="pw-warnings">
          <div class="check-item" id="warn-seq">   <div class="check-dot"></div> Sequential chars (abc, 123)</div>
          <div class="check-item" id="warn-rep">   <div class="check-dot"></div> Repeated chars (aaa, 111)</div>
          <div class="check-item" id="warn-kbd">   <div class="check-dot"></div> Keyboard walks (qwerty)</div>
          <div class="check-item" id="warn-common"> <div class="check-dot"></div> Common words/patterns</div>
          <div class="check-item" id="warn-leet">  <div class="check-dot"></div> Leet substitution detected</div>
          <div class="check-item" id="warn-date">  <div class="check-dot"></div> Date-like pattern (2024)</div>
        </div>
      </div>
    </div>

    <div class="card" style="margin-top:16px;">
      <div class="card-title">Recommendations</div>
      <div id="pw-recommendations" style="font-size:0.8rem; color:var(--muted); line-height:1.8;">
        > Start typing a password to see personalized recommendations...
      </div>
    </div>

  </div>

  <div class="panel" id="panel-1">
    <div class="section-title"><span class="accent">>_</span> Hash Generator & Verifier</div>
    <div class="section-desc">Generate and verify cryptographic hashes in-browser.</div>

    <div class="algo-chips" id="algo-chips">
      <button class="algo-chip active" onclick="setAlgo('MD5',this)">MD5</button>
